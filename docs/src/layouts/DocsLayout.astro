---
const { frontmatter } = Astro.props;
const currentPath = Astro.url.pathname;
const base = import.meta.env.BASE_URL.replace(/\/$/, "");

const normalize = (path) => path.replace(/\/$/, "").toLowerCase();

const sections = [
  {
    title: "Getting Started",
    tint: "sage",
    links: [
      { label: "Introduction", href: `${base}/` },
      { label: "Installation", href: `${base}/installation/` },
      { label: "Configuration", href: `${base}/configuration/` },
      { label: "cPanel Env Setup", href: `${base}/cpanel-env/` },
    ],
  },
  {
    title: "Usage & Architecture",
    tint: "sky",
    links: [
      { label: "Core Concepts", href: `${base}/concepts/` },
      { label: "CLI Commands", href: `${base}/commands/` },
      { label: "Cookbook & Examples", href: `${base}/cookbook/` },
      { label: "Extending & Overriding", href: `${base}/extending/` },
      { label: "AI Agent Skill", href: `${base}/agent-skill/` },
      { label: "Security Model", href: `${base}/security/` },
      { label: "Troubleshooting", href: `${base}/troubleshooting/` },
    ],
  },
];

const githubUrl = "https://github.com/inja-online/ftp-deployer";
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href={`${base}/favicon.svg`} />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />
    <title>{frontmatter.title} | FTP Deployer</title>
    {frontmatter.description && <meta name="description" content={frontmatter.description} />}
    <link rel="canonical" href={`https://inja-online.github.io/ftp-deployer${Astro.url.pathname}`} />
    <meta property="og:title" content={`${frontmatter.title} | FTP Deployer`} />
    {frontmatter.description && <meta property="og:description" content={frontmatter.description} />}
    <meta property="og:type" content="website" />
    <meta property="og:url" content={`https://inja-online.github.io/ftp-deployer${Astro.url.pathname}`} />
    <meta property="og:site_name" content="FTP Deployer" />
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content={`${frontmatter.title} | FTP Deployer`} />
    {frontmatter.description && <meta name="twitter:description" content={frontmatter.description} />}
    
    <!-- Google Fonts - Manrope substitute for Forma DJR Micro -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Manrope:wght@400;500;600;700&display=swap" rel="stylesheet">
    
    <!-- Theme Toggle Initialization Script to prevent flash of light theme -->
    <script is:inline>
      (function () {
        const storedTheme = localStorage.getItem('theme');
        if (storedTheme === 'dark' || (!storedTheme && window.matchMedia('(prefers-color-scheme: dark)').matches)) {
          document.documentElement.classList.add('dark');
        } else {
          document.documentElement.classList.remove('dark');
        }
      })();
    </script>
  </head>
  <body>
    <a class="skip-link" href="#main-content">Skip to content</a>

    <!-- nav-bar-top: Clean, low-profile header with toggle -->
    <header class="nav-bar-top">
      <div class="nav-bar-container">
        <a href={`${base}/`} class="brand-block">
          <span class="brand-logo">
            <svg width="20" height="20" viewBox="0 0 30 30" fill="none" xmlns="http://www.w3.org/2000/svg">
              <!-- Folder Outline -->
              <path d="M1.5 0C.678 0 0 .678 0 1.5v23c0 .822.678 1.5 1.5 1.5h7c.667 0 .66-1 0-1h-7c-.286 0-.5-.214-.5-.5v-23c0-.286.214-.5.5-.5h7c.5 0 .647.007.777.072.13.066.37.282.87.782l3 3c.516.516.865.81 1.248.98.382.17.733.166 1.105.166h13c.286 0 .5.214.5.5v18c0 .286-.214.5-.5.5h-6c-.646 0-.672 1 0 1h6c.822 0 1.5-.678 1.5-1.5v-18c0-.822-.678-1.5-1.5-1.5h-13c-.373 0-.52-.002-.7-.082-.182-.08-.46-.285-.946-.772l-3-3c-.5-.5-.762-.784-1.13-.968C9.353-.007 9 0 8.5 0z" fill="var(--colors-primary)" />
              <!-- Letters (FTP) -->
              <path d="M7.5 10c-.276 0-.5.224-.5.5v6c0 .66 1 .668 1 0V14h1.5c.665 0 .65-1 0-1H8v-2h2.5c.66.01.66-1 0-1z" fill="var(--colors-ink-deep)" />
              <path d="M13.5 10c-.66 0-.66 1 0 1H15v5.5c0 .67 1 .665 1 0V11h1.5c.66.01.662-1 0-1z" fill="var(--colors-ink-deep)" />
              <path d="M20.5 10c-.276 0-.5.224-.5.5v6c0 .672 1 .653 1 0V14h.5c.832 0 1.468-.206 1.896-.59.43-.383.604-.92.604-1.41 0-.49-.175-1.027-.604-1.41-.428-.384-1.064-.59-1.896-.59zm.5 1h.5c.668 0 1.032.16 1.23.336.195.175.27.39.27.664 0 .273-.075.49-.27.664-.198.176-.562.336-1.23.336H21z" fill="var(--colors-ink-deep)" />
              <!-- Arrow -->
              <path d="M15.5 19c-.13.002-.26.055-.353.146l-3.994 3.995c-.464.446.26 1.17.706.707l3.64-3.642 3.64 3.642c.454.472 1.175-.257.707-.706l-3.994-3.994c-.096-.095-.218-.148-.353-.146zm0 3c.277 0 .5.223.5.5v7c0 .277-.223.5-.5.5s-.5-.223-.5-.5v-7c0-.277.223-.5.5-.5z" fill="var(--colors-bloom-coral)" />
            </svg>
          </span>
          <span class="banner-title">FTP DEPLOYER</span>
        </a>
        <div class="nav-actions-right">
          <a class="nav-link-top" href={githubUrl} target="_blank" rel="noopener noreferrer">GitHub</a>
          <button id="themeToggle" class="theme-toggle" aria-label="Toggle theme" title="Toggle theme">
            <!-- Sun icon (shown in dark mode) -->
            <svg class="sun-icon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <circle cx="12" cy="12" r="4"></circle>
              <path d="M12 2v2"></path>
              <path d="M12 20v2"></path>
              <path d="M4.93 4.93l1.41 1.41"></path>
              <path d="M17.66 17.66l1.41 1.41"></path>
              <path d="M2 12h2"></path>
              <path d="M20 12h2"></path>
              <path d="M6.34 17.66l-1.41 1.41"></path>
              <path d="M19.07 4.93l-1.41 1.41"></path>
            </svg>
            <!-- Moon icon (shown in light mode) -->
            <svg class="moon-icon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M12 3a6 6 0 0 0 9 9 9 9 0 1 1-9-9Z"></path>
            </svg>
          </button>
          <button class="mobile-toggle" aria-label="Toggle navigation" aria-expanded="false" aria-controls="sidebar" id="mobileToggle">
            MENU
          </button>
        </div>
      </div>
    </header>

    <!-- layout-container: main content and sidebar -->
    <div class="layout-container">
      <aside class="sidebar" id="sidebar">
        <nav class="nav" aria-label="Documentation navigation">
          {sections.map(section => (
            <div class="nav-section">
              <h2 class="nav-section-title">{section.title}</h2>
              <ul class="nav-list">
                {section.links.map(link => {
                  const isActive = normalize(currentPath) === normalize(link.href) ||
                    (normalize(currentPath) === "" && normalize(link.href) === normalize(base));
                  return (
                    <li class="nav-item">
                      <a href={link.href} class={`nav-link ${isActive ? 'active' : ''}`} aria-current={isActive ? 'page' : undefined}>
                        {link.label}
                      </a>
                    </li>
                  );
                })}
              </ul>
            </div>
          ))}
        </nav>
      </aside>

      <main class="content" id="main-content">
        <article class="prose">
          <slot />
        </article>
      </main>
    </div>

    <!-- footer-dark: Clean, minimal dark slab footer -->
    <footer class="footer-dark">
      <div class="footer-container">
        <div class="footer-bottom">
          <div class="footer-bottom-left">
            <svg width="16" height="16" viewBox="0 0 30 30" fill="none" class="footer-logo" xmlns="http://www.w3.org/2000/svg">
              <path d="M1.5 0C.678 0 0 .678 0 1.5v23c0 .822.678 1.5 1.5 1.5h7c.667 0 .66-1 0-1h-7c-.286 0-.5-.214-.5-.5v-23c0-.286.214-.5.5-.5h7c.5 0 .647.007.777.072.13.066.37.282.87.782l3 3c.516.516.865.81 1.248.98.382.17.733.166 1.105.166h13c.286 0 .5.214.5.5v18c0 .286-.214.5-.5.5h-6c-.646 0-.672 1 0 1h6c.822 0 1.5-.678 1.5-1.5v-18c0-.822-.678-1.5-1.5-1.5h-13c-.373 0-.52-.002-.7-.082-.182-.08-.46-.285-.946-.772l-3-3c-.5-.5-.762-.784-1.13-.968C9.353-.007 9 0 8.5 0z" fill="var(--colors-footer-text, var(--colors-steel))" />
              <path d="M7.5 10c-.276 0-.5.224-.5.5v6c0 .66 1 .668 1 0V14h1.5c.665 0 .65-1 0-1H8v-2h2.5c.66.01.66-1 0-1z" fill="var(--colors-footer-text, var(--colors-steel))" />
              <path d="M13.5 10c-.66 0-.66 1 0 1H15v5.5c0 .67 1 .665 1 0V11h1.5c.66.01.662-1 0-1z" fill="var(--colors-footer-text, var(--colors-steel))" />
              <path d="M20.5 10c-.276 0-.5.224-.5.5v6c0 .672 1 .653 1 0V14h.5c.832 0 1.468-.206 1.896-.59.43-.383.604-.92.604-1.41 0-.49-.175-1.027-.604-1.41-.428-.384-1.064-.59-1.896-.59zm.5 1h.5c.668 0 1.032.16 1.23.336.195.175.27.39.27.664 0 .273-.075.49-.27.664-.198.176-.562.336-1.23.336H21z" fill="var(--colors-footer-text, var(--colors-steel))" />
              <path d="M15.5 19c-.13.002-.26.055-.353.146l-3.994 3.995c-.464.446.26 1.17.706.707l3.64-3.642 3.64 3.642c.454.472 1.175-.257.707-.706l-3.994-3.994c-.096-.095-.218-.148-.353-.146zm0 3c.277 0 .5.223.5.5v7c0 .277-.223.5-.5.5s-.5-.223-.5-.5v-7c0-.277.223-.5.5-.5z" fill="var(--colors-footer-text, var(--colors-steel))" />
            </svg>
            <span class="footer-copyright">© 2026 FTP Deployer · Documentation for FTP-only Laravel deployment.</span>
          </div>
          <div class="footer-bottom-right">
            <a href={githubUrl} class="footer-meta-link" target="_blank" rel="noopener noreferrer">GitHub</a>
            <a href={`${base}/security/`} class="footer-meta-link">Security Policy</a>
          </div>
        </div>
      </div>
    </footer>

    <!-- mermaidModal: SVG Zoom Modal -->
    <div id="mermaidModal" class="mermaid-modal" aria-hidden="true">
      <div class="mermaid-modal-overlay"></div>
      <div class="mermaid-modal-content">
        <button id="closeMermaidModal" class="mermaid-modal-close" aria-label="Close modal">&times;</button>
        <img id="mermaidModalImage" src="" alt="Zoomed Diagram" class="mermaid-modal-img" />
        <a id="mermaidModalDownload" href="" download class="button-primary mermaid-modal-download">Download SVG</a>
      </div>
    </div>

    <script>
      // Theme Toggle logic
      const themeToggle = document.getElementById('themeToggle');
      if (themeToggle) {
        themeToggle.addEventListener('click', () => {
          const isDark = document.documentElement.classList.toggle('dark');
          localStorage.setItem('theme', isDark ? 'dark' : 'light');
        });
      }

      const toggle = document.getElementById('mobileToggle');
      const sidebar = document.getElementById('sidebar');

      if (toggle && sidebar) {
        toggle.addEventListener('click', (e) => {
          const isOpen = sidebar.classList.toggle('open');
          toggle.setAttribute('aria-expanded', String(isOpen));
          e.stopPropagation();
        });

        document.addEventListener('click', (e) => {
          if (sidebar.classList.contains('open') && !sidebar.contains(e.target as Node) && e.target !== toggle) {
            sidebar.classList.remove('open');
            toggle.setAttribute('aria-expanded', 'false');
          }
        });
      }

      document.querySelectorAll('.prose blockquote').forEach((bq) => {
        const p = bq.querySelector('p');
        if (!p) return;

        const match = p.innerHTML.match(/^\[!(NOTE|WARNING|TIP|IMPORTANT|CAUTION)\](?:\s*<br\s*\/?>)?\s*/i);
        if (match) {
          bq.classList.add(match[1].toLowerCase());
          p.innerHTML = p.innerHTML.replace(/^\[!(NOTE|WARNING|TIP|IMPORTANT|CAUTION)\](?:\s*<br\s*\/?>)?\s*/i, '');
        }
      });

      // SVG Diagram Zoom & Download controls
      const modal = document.getElementById('mermaidModal');
      const modalImg = document.getElementById('mermaidModalImage') as HTMLImageElement | null;
      const modalDownload = document.getElementById('mermaidModalDownload') as HTMLAnchorElement | null;
      const closeModal = document.getElementById('closeMermaidModal');
      const modalOverlay = modal?.querySelector('.mermaid-modal-overlay');

      function openModal(src: string) {
        if (modal && modalImg && modalDownload) {
          modalImg.src = src;
          modalDownload.href = src;
          modalDownload.download = src.split('/').pop() || 'diagram.svg';
          modal.classList.add('active');
          document.body.style.overflow = 'hidden';
        }
      }

      function close() {
        if (modal) {
          modal.classList.remove('active');
          document.body.style.overflow = '';
        }
      }

      if (closeModal) closeModal.addEventListener('click', close);
      if (modalOverlay) modalOverlay.addEventListener('click', close);
      
      document.addEventListener('keydown', (e) => {
        if (e.key === 'Escape') close();
      });

      document.querySelectorAll('.mermaid').forEach((container) => {
        const img = container.querySelector('img');
        if (!img) return;
        const imgSrc = img.getAttribute('src');
        if (!imgSrc) return;
        
        container.classList.add('has-controls');
        
        // Create controls container
        const controls = document.createElement('div');
        controls.className = 'mermaid-controls';
        
        // Zoom button
        const btnZoom = document.createElement('button');
        btnZoom.className = 'mermaid-btn btn-zoom';
        btnZoom.type = 'button';
        btnZoom.textContent = 'Zoom';
        btnZoom.addEventListener('click', () => openModal(imgSrc));
        
        // Download button
        const btnDownload = document.createElement('a');
        btnDownload.className = 'mermaid-btn btn-download';
        btnDownload.href = imgSrc;
        btnDownload.download = imgSrc.split('/').pop() || 'diagram.svg';
        btnDownload.textContent = 'Download';
        
        controls.appendChild(btnZoom);
        controls.appendChild(btnDownload);
        container.appendChild(controls);
        
        // Image click triggers zoom
        img.style.cursor = 'zoom-in';
        img.addEventListener('click', () => openModal(imgSrc));
      });
    </script>
  </body>
</html>

<style is:global>
  :root {
    /* Brand & Accent */
    --colors-primary: #024ad8;
    --colors-primary-bright: #296ef9;
    --colors-primary-deep: #0e3191;
    --colors-primary-soft: #c9e0fc;
    
    /* Surfaces */
    --colors-canvas: #ffffff;
    --colors-paper: #ffffff;
    --colors-cloud: #f7f7f7;
    --colors-fog: #e8e8e8;
    --colors-steel: #c2c2c2;
    --colors-hairline: #e8e8e8;
    
    /* Semantic / Accent Highlights */
    --colors-bloom-coral: #ff5050;
    --colors-bloom-rose: #f9d4d2;
    --colors-bloom-deep: #b3262b;
    --colors-bloom-wine: #5a1313;
    
    --colors-blockquote-important-bg: #e6f0fa;
    --colors-footer-bg: #1a1a1a;
    --colors-footer-text: #c2c2c2;
    --colors-nav-active-text: var(--colors-primary-deep);
    
    --colors-storm-mist: #8ebdce;
    --colors-storm-sea: #7fadbe;
    --colors-storm-deep: #356373;
    
    /* Ink Tones */
    --colors-ink: #1a1a1a;
    --colors-ink-deep: #000000;
    --colors-ink-soft: #292929;
    --colors-on-ink: #ffffff;
    --colors-charcoal: #3d3d3d;
    --colors-graphite: #636363;
  }

  html.dark {
    /* Brand & Accent overrides for dark theme */
    --colors-primary: #296ef9;
    --colors-primary-bright: #4f83f8;
    --colors-primary-deep: #0044cc;
    --colors-primary-soft: rgba(41, 110, 249, 0.15);
    
    /* Surfaces overrides for dark theme */
    --colors-canvas: #0c0e12;
    --colors-paper: #161920;
    --colors-cloud: #1b1e26;
    --colors-fog: #242934;
    --colors-steel: #485264;
    --colors-hairline: #222630;
    
    /* Semantic / Accent Highlights overrides for dark theme */
    --colors-bloom-coral: #ff6b6b;
    --colors-bloom-rose: #3a1e1e;
    --colors-bloom-deep: #f87171;
    --colors-bloom-wine: #fca5a5;
    
    --colors-blockquote-important-bg: #1e293b;
    --colors-footer-bg: #07080a;
    --colors-footer-text: #8a99ad;
    --colors-nav-active-text: var(--colors-ink-deep);
    
    --colors-storm-mist: #2b3942;
    --colors-storm-sea: #222d35;
    --colors-storm-deep: #6f95a8;
    
    /* Ink / Typography Tones overrides for dark theme */
    --colors-ink: #e2e8f0;
    --colors-ink-deep: #ffffff;
    --colors-ink-soft: #cbd5e1;
    --colors-on-ink: #ffffff;
    --colors-charcoal: #94a3b8;
    --colors-graphite: #64748b;
    
    /* Shadows & Elevation overrides for dark theme */
    --shadow-soft-lift: 0 4px 12px rgba(0, 0, 0, 0.3);
    --shadow-floating-modal: 0 8px 32px rgba(0, 0, 0, 0.5);
  }

  /* Fonts (Manrope as best open-source substitute for Forma DJR Micro) */
  :root {
    --font-display: 'Manrope', sans-serif;
    --font-ui: 'Manrope', sans-serif;
    --font-body: 'Manrope', sans-serif;
    --font-mono: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;

    /* Spacing System (Base 8px) */
    --spacing-xxs: 4px;
    --spacing-xs: 8px;
    --spacing-sm: 12px;
    --spacing-md: 16px;
    --spacing-lg: 20px;
    --spacing-xl: 24px;
    --spacing-xxl: 32px;
    --spacing-section: 80px;

    /* Border Radius Scale */
    --rounded-none: 0px;
    --rounded-xs: 2px;
    --rounded-sm: 3px;
    --rounded-md: 4px;
    --rounded-lg: 8px;
    --rounded-xl: 16px;
    --rounded-pill: 9999px;

    /* Shadows & Elevation */
    --shadow-soft-lift: 0 2px 8px rgba(26, 26, 26, 0.08);
    --shadow-floating-modal: 0 8px 24px rgba(26, 26, 26, 0.12);
  }

  * { box-sizing: border-box; }

  html, body {
    margin: 0;
    min-height: 100%;
    background: var(--colors-canvas);
    color: var(--colors-ink);
    font-family: var(--font-body);
    font-size: 16px;
    line-height: 1.4;
  }

  a {
    color: var(--colors-primary);
    text-decoration: underline;
    text-underline-offset: 2px;
    transition: color 0.2s ease;
  }

  a:hover {
    color: var(--colors-primary-deep);
  }

  a:focus-visible,
  button:focus-visible {
    outline: 2px solid var(--colors-ink-deep);
    outline-offset: 2px;
  }

  .skip-link {
    position: absolute;
    left: 16px;
    top: 16px;
    z-index: 1000;
    padding: 8px 16px;
    background: var(--colors-canvas);
    border: 1px solid var(--colors-ink);
    border-radius: var(--rounded-md);
    font-family: var(--font-ui);
    font-size: 14px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.7px;
    color: var(--colors-ink);
    text-decoration: none;
    transform: translateY(-150%);
    transition: transform 0.2s ease;
  }

  .skip-link:focus { transform: translateY(0); }

  /* Nav Bar Top */
  .nav-bar-top {
    background: var(--colors-canvas);
    border-bottom: 1px solid var(--colors-hairline);
    height: 56px;
    position: sticky;
    top: 0;
    z-index: 100;
  }
  .nav-bar-container {
    max-width: 1366px;
    margin: 0 auto;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0 var(--spacing-xl);
  }
  .brand-block {
    display: flex;
    align-items: center;
    gap: var(--spacing-xs);
    color: var(--colors-ink);
    text-decoration: none;
  }
  .brand-logo {
    display: flex;
    align-items: center;
  }
  .banner-title {
    font-family: var(--font-display);
    font-size: 18px;
    font-weight: 700;
    color: var(--colors-ink-deep);
    letter-spacing: -0.5px;
  }
  .nav-actions-right {
    display: flex;
    align-items: center;
    gap: var(--spacing-md);
  }
  .nav-link-top {
    color: var(--colors-ink);
    font-family: var(--font-ui);
    font-size: 14px;
    font-weight: 500;
    text-decoration: none;
    padding: 8px 12px;
  }
  .nav-link-top:hover {
    text-decoration: underline;
  }
  .mobile-toggle {
    display: none;
  }

  /* Button General Components */
  .button-primary {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    background: var(--colors-primary);
    color: #ffffff;
    font-family: var(--font-ui);
    font-size: 13px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.7px;
    padding: 12px 24px;
    height: 44px;
    border-radius: var(--rounded-md);
    border: none;
    text-decoration: none;
    cursor: pointer;
    transition: background 0.2s ease;
  }
  .button-primary:hover {
    background: var(--colors-primary-deep);
    color: #ffffff;
  }
  .button-outline {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    background: var(--colors-canvas);
    color: var(--colors-primary);
    border: 1px solid var(--colors-primary);
    font-family: var(--font-ui);
    font-size: 13px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.7px;
    padding: 12px 24px;
    height: 44px;
    border-radius: var(--rounded-md);
    text-decoration: none;
    cursor: pointer;
    transition: all 0.2s ease;
  }
  .button-outline:hover {
    background: var(--colors-primary-soft);
